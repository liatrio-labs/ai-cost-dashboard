# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ----------------------------------------------------------------------------
# Provider API keys (org-level admin keys, used directly by the collectors).
# Set the ones you use; a provider with no key is skipped at collection time.
# ----------------------------------------------------------------------------
ANTHROPIC_ADMIN_KEY=sk-ant-admin-...        # platform.claude.com Admin API
# ANTHROPIC_ORG_ID=
CLAUDE_AI_ANALYTICS_KEY=                     # claude.ai Enterprise Analytics (read:analytics)
# CLAUDE_AI_ORG_ID=
OPENAI_ADMIN_KEY=sk-admin-...                # platform.openai.com Costs/Usage API
# OPENAI_ORG_ID=
CURSOR_ADMIN_KEY=                            # Cursor Admin API (Business/Team)
# CURSOR_TEAM_ID=
VERCEL_TOKEN=                                # Vercel REST API token (Team)
# VERCEL_TEAM_ID=

# ----------------------------------------------------------------------------
# Owner attribution: all collected records are stored under one owner user so
# the dashboard shows a single shared, org-wide view. Set the UUID directly, or
# leave it unset to resolve by email (default robert@liatrio.com).
# ----------------------------------------------------------------------------
# DASHBOARD_OWNER_USER_ID=
DASHBOARD_OWNER_EMAIL=robert@liatrio.com

# Server Configuration
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# Shared secret authenticating scheduled collection callers (Vercel Cron ->
# POST /api/collection/run-all). Must match CRON_SECRET on the Vercel project.
# Falls back to CRON_SECRET if this is unset.
COLLECTION_TRIGGER_SECRET=your-shared-cron-secret

# Scheduler Configuration
# Collection is driven by Vercel Cron by default. Enable the in-process
# APScheduler ONLY for a standalone deployment without Vercel Cron, otherwise
# collectors would run twice.
ENABLE_INTERNAL_SCHEDULER=false

# Logging
LOG_LEVEL=INFO

# Monitoring and Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
RELEASE_VERSION=1.0.0
